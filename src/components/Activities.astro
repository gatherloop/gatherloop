---
import activitiesData from "../data/activities.json";
import { withBase } from "../utils/url";
import { DEFAULT_LOCALE, t, type Locale } from "../i18n";
import type { Activity } from "../types";

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const dict = t(locale).activities;
const activities: Activity[] = activitiesData[locale];
---

<section class="activities" aria-label={dict.ariaLabel}>
  <h2 class="section-title">{dict.sectionTitle}</h2>

  <div class="carousel" role="region" aria-roledescription="carousel" aria-label={dict.ariaLabel}>
    <ul class="carousel-track" id="activities-track">
      {
        activities.map((activity, index) => (
          <li class="carousel-slide" id={`activity-slide-${index}`}>
            <img
              class="slide-image"
              src={withBase(activity.image)}
              alt={activity.title}
              width="800"
              height="600"
              loading="lazy"
            />
            <h3 class="slide-title">{activity.title}</h3>
            <p class="slide-description">{activity.description}</p>
          </li>
        ))
      }
    </ul>

    <button type="button" class="carousel-arrow carousel-arrow-prev" id="activities-prev" aria-label={dict.prevLabel}>
      <span aria-hidden="true">‹</span>
    </button>
    <button type="button" class="carousel-arrow carousel-arrow-next" id="activities-next" aria-label={dict.nextLabel}>
      <span aria-hidden="true">›</span>
    </button>

    <div class="carousel-dots" id="activities-dots" data-go-to-slide-template={dict.goToSlideTemplate}>
      {
        activities.map((_, index) => (
          <button
            type="button"
            class="carousel-dot"
            data-index={index}
            aria-label={dict.goToSlideTemplate.replace("{index}", String(index + 1))}
            aria-current={index === 0 ? "true" : undefined}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .activities {
    margin-top: 2.5rem;
  }

  .section-title {
    font-size: 1.375rem;
    margin-bottom: 1rem;
    text-align: center;
  }

  .carousel {
    position: relative;
  }

  .carousel-track {
    display: flex;
    gap: 1rem;
    margin: 0;
    padding: 0 2.5rem 0.75rem;
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: 2.5rem;
    scrollbar-width: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-slide {
    flex: 0 0 100%;
    scroll-snap-align: center;
    border-radius: var(--radius-lg);
    background: #fff;
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .slide-image {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .slide-title {
    margin: 1rem 1rem 0;
    font-size: 1.0625rem;
  }

  .slide-description {
    margin: 0.375rem 1rem 1rem;
    opacity: 0.85;
    font-size: 0.9375rem;
  }

  .carousel-arrow {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: #fff;
    color: var(--color-accent);
    box-shadow: var(--shadow-card);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-arrow:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .carousel-arrow-prev {
    left: 0;
  }

  .carousel-arrow-next {
    right: 0;
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: var(--color-border);
    cursor: pointer;
  }

  .carousel-dot[aria-current="true"] {
    background: var(--color-accent);
  }

  @media (min-width: 560px) {
    .carousel-slide {
      flex-basis: calc(50% - 0.5rem);
    }
  }
</style>

<script>
  const track = document.getElementById("activities-track");
  const prevButton = document.getElementById("activities-prev");
  const nextButton = document.getElementById("activities-next");
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>("#activities-dots .carousel-dot"));

  if (track && dots.length > 0) {
    const slides = Array.from(track.children) as HTMLElement[];

    function scrollToSlide(index: number) {
      slides[index]?.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
    }

    function setActiveDot(index: number) {
      dots.forEach((dot, dotIndex) => {
        if (dotIndex === index) {
          dot.setAttribute("aria-current", "true");
        } else {
          dot.removeAttribute("aria-current");
        }
      });
    }

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => scrollToSlide(index));
    });

    prevButton?.addEventListener("click", () => {
      const current = slides.findIndex((slide) => slide.classList.contains("is-active"));
      scrollToSlide(Math.max(0, (current === -1 ? 0 : current) - 1));
    });

    nextButton?.addEventListener("click", () => {
      const current = slides.findIndex((slide) => slide.classList.contains("is-active"));
      scrollToSlide(Math.min(slides.length - 1, (current === -1 ? 0 : current) + 1));
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const index = slides.indexOf(entry.target as HTMLElement);
          if (index === -1) return;
          if (entry.isIntersecting) {
            slides[index]?.classList.add("is-active");
            setActiveDot(index);
          } else {
            slides[index]?.classList.remove("is-active");
          }
        });
      },
      { root: track, threshold: 0.6 },
    );

    slides.forEach((slide) => observer.observe(slide));
  }
</script>
