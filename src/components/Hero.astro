---
import { withBase } from "../utils/url";
import { WHATSAPP_RESERVATION } from "../consts";
import { DEFAULT_LOCALE, t, type Locale } from "../i18n";
import LanguageSwitch from "./LanguageSwitch.astro";

interface Props {
  locale?: Locale;
  path: string;
}

const { locale = DEFAULT_LOCALE, path } = Astro.props;
const dict = t(locale).hero;

const heroImageSrc = withBase("/images/hero.webp");
const logoSrc = withBase("/images/logo.webp");
---

<section class="hero">
  <div class="hero-top">
    <LanguageSwitch locale={locale} path={path} />
  </div>

  <img
    class="hero-image"
    src={heroImageSrc}
    alt={dict.imageAlt}
    width="960"
    height="720"
  />

  <div class="brand">
    <img class="logo" src={logoSrc} alt="" />
  </div>

  <h1 class="tagline">{dict.tagline}</h1>
  <p class="tagline-sub">{dict.taglineSub}</p>

  <a
    class="reserve-button"
    href={WHATSAPP_RESERVATION}
    target="_blank"
    rel="noopener"
    aria-label={dict.reserveAriaLabel}
  >
    {dict.reserveButton}
  </a>
</section>

<style>
  .hero {
    padding-top: 1rem;
    text-align: center;
  }

  .hero-top {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  .hero-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  .brand {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1rem;
  }

  .logo {
    width: 160px;
  }

  .tagline {
    margin-top: 1rem;
    font-size: 1.5rem;
    line-height: 1.25;
  }

  .tagline-sub {
    margin-top: 0.5rem;
    opacity: 0.85;
  }

  .reserve-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    margin-top: 1.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-sm);
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    box-shadow: var(--shadow-card);
    font-weight: 700;
    text-decoration: none;
  }

  @media (min-width: 480px) {
    .tagline {
      font-size: 1.75rem;
    }

    .logo {
      width: 180px;
    }
  }
</style>
