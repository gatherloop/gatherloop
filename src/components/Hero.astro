---
import { withBase } from "../utils/url";
import { WHATSAPP_RESERVATION } from "../consts";
import { DEFAULT_LOCALE, t, type Locale } from "../i18n";
import LanguageSwitch from "./LanguageSwitch.astro";

interface Props {
  locale?: Locale;
  path: string;
}

const { locale = DEFAULT_LOCALE, path } = Astro.props;
const dict = t(locale).hero;

const heroImageSrc = withBase("/images/hero.webp");
const logoSrc = withBase("/images/logo.webp");
---

<section class="hero">
  <div class="hero-media">
    <img
      class="hero-image"
      src={heroImageSrc}
      alt={dict.imageAlt}
      width="960"
      height="720"
    />

    <div class="hero-scrim"></div>

    <div class="hero-brand">
      <img class="logo" src={logoSrc} alt="Gatherloop" />
    </div>

    <div class="hero-top">
      <LanguageSwitch locale={locale} path={path} />
    </div>

    <div class="hero-overlay">
      <h1 class="tagline">{dict.tagline}</h1>
      <p class="tagline-sub">{dict.taglineSub}</p>
      <a
        class="reserve-button"
        href={WHATSAPP_RESERVATION}
        target="_blank"
        rel="noopener"
        aria-label={dict.reserveAriaLabel}
      >
        {dict.reserveButton}
      </a>
    </div>
  </div>
</section>

<div class="sticky-reserve" id="sticky-reserve">
  <a
    class="sticky-reserve-button"
    href={WHATSAPP_RESERVATION}
    target="_blank"
    rel="noopener"
    aria-label={dict.reserveAriaLabel}
  >
    {dict.reserveButton}
  </a>
</div>

<script>
  const inlineButton = document.querySelector<HTMLElement>(".hero .reserve-button");
  const stickyBar = document.getElementById("sticky-reserve");

  if (inlineButton && stickyBar && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      ([entry]) => stickyBar.classList.toggle("is-visible", !entry.isIntersecting),
    );
    observer.observe(inlineButton);
  }
</script>

<style>
  .hero {
    text-align: center;
  }

  .hero-media {
    position: relative;
    overflow: hidden;
    width: 100vw;
    margin-inline: calc(50% - 50vw);
  }

  .hero-image {
    width: 100%;
    height: 62vh;
    min-height: 460px;
    max-height: 680px;
    object-fit: cover;
    display: block;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(10, 10, 15, 0.55), rgba(10, 10, 15, 0) 30%),
      linear-gradient(to top, rgba(10, 10, 15, 0.9), rgba(10, 10, 15, 0.1) 60%);
    pointer-events: none;
  }

  .hero-brand {
    position: absolute;
    inset-block-start: 0.75rem;
    inset-inline-start: 0.75rem;
  }

  .hero-top {
    position: absolute;
    inset-block-start: 0.75rem;
    inset-inline-end: 0.75rem;
  }

  .hero-top :global(.language-switch) {
    padding: 0.25rem;
    border-radius: var(--radius-sm);
    background: rgba(15, 15, 20, 0.35);
    backdrop-filter: blur(4px);
  }

  .hero-top :global(.language-switch-link) {
    border-color: transparent;
    color: #fff;
  }

  .hero-top :global(.language-switch-link[aria-current="true"]) {
    border-color: transparent;
  }

  .hero-overlay {
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    padding: 4rem 1.5rem 2.25rem;
  }

  .logo {
    width: 130px;
    filter: drop-shadow(0 1px 6px rgba(0, 0, 0, 0.55));
  }

  .tagline {
    max-width: 22rem;
    font-size: 1.5rem;
    line-height: 1.25;
    color: #fff;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);
  }

  .tagline-sub {
    max-width: 26rem;
    color: #fff;
    opacity: 0.9;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);
  }

  .reserve-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    margin-top: 0.25rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-sm);
    background: #fff;
    color: var(--color-accent);
    box-shadow: var(--shadow-card);
    font-weight: 700;
    text-decoration: none;
  }

  :global(body) {
    padding-block-end: calc(4.5rem + env(safe-area-inset-bottom));
  }

  .sticky-reserve {
    position: fixed;
    inset-inline: 0;
    inset-block-end: 0;
    z-index: 10;
    display: flex;
    justify-content: center;
    padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom));
    background: rgba(250, 246, 240, 0.92);
    backdrop-filter: blur(6px);
    box-shadow: 0 -2px 10px rgba(38, 34, 29, 0.12);
    transform: translateY(100%);
    transition: transform 0.25s ease;
  }

  .sticky-reserve.is-visible {
    transform: translateY(0);
  }

  .sticky-reserve-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: calc(var(--content-max-width) - 2rem);
    min-height: 44px;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-sm);
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    font-weight: 700;
    text-decoration: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .sticky-reserve {
      transition: none;
    }
  }

  @media (min-width: 480px) {
    .tagline {
      max-width: 28rem;
      font-size: 1.9rem;
    }

    .tagline-sub {
      font-size: 1.05rem;
    }

    .logo {
      width: 150px;
    }
  }
</style>
