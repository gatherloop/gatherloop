---
import { withBase } from "../utils/url";
import { DEFAULT_LOCALE, t, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const dict = t(locale).hero;

const heroImageSrc = withBase("/images/hero.webp");
const logoSrc = withBase("/images/logo.webp");
---

<section class="hero">
  <div class="hero-image-wrap">
    <img
      class="hero-image"
      src={heroImageSrc}
      alt={dict.imageAlt}
      width="960"
      height="720"
    />
  </div>

  <div class="brand">
    <img class="logo" src={logoSrc} alt="" />
  </div>

  <h1 class="tagline">{dict.tagline}</h1>
  <p class="tagline-sub">{dict.taglineSub}</p>
</section>

<style>
  .hero {
    padding-top: 1.5rem;
    text-align: center;
  }

  .hero-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  @media (min-width: 720px) {
    .hero-image-wrap {
      width: 100vw;
      position: relative;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      justify-content: center;
    }

    .hero-image {
      max-width: 960px;
    }
  }

  .brand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .logo {
    width: 250px;
  }

  .brand-name {
    font-size: 1.125rem;
    font-weight: 700;
  }

  .tagline {
    margin-top: 1rem;
    font-size: 1.5rem;
    line-height: 1.25;
  }

  .tagline-sub {
    margin-top: 0.5rem;
    opacity: 0.85;
  }

  @media (min-width: 480px) {
    .tagline {
      font-size: 1.75rem;
    }
  }
</style>
