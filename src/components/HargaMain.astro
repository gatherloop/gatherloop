---
import { withBase } from "../utils/url";

const hargaMainImageSrc = withBase("/images/harga-main-placeholder.svg");
---

<section class="harga-main">
  <h2 class="section-title">Harga Main</h2>
  <img
    class="harga-main-image"
    src={hargaMainImageSrc}
    alt="Daftar harga main Gatherloop"
    width="480"
    height="600"
    loading="lazy"
  />
</section>

<style>
  .harga-main {
    margin-top: 2.5rem;
    text-align: center;
  }

  .section-title {
    font-size: 1.375rem;
    margin-bottom: 1rem;
  }

  .harga-main-image {
    width: 100%;
    height: auto;
    max-width: 480px;
    margin-inline: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }
</style>
