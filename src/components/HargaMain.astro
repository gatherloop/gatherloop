---
import { withBase } from "../utils/url";
import { DEFAULT_LOCALE, t, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const dict = t(locale).hargaMain;

const hargaMainImageSrc = withBase("/images/harga main.webp");
---

<section class="harga-main">
  <h2 class="section-title">{dict.sectionTitle}</h2>
  <img
    class="harga-main-image"
    src={hargaMainImageSrc}
    alt={dict.imageAlt}
    width="480"
    height="600"
    loading="lazy"
  />
  {dict.caption && <p class="harga-main-caption">{dict.caption}</p>}
</section>

<style>
  .harga-main {
    margin-top: 2.5rem;
    text-align: center;
  }

  .section-title {
    font-size: 1.375rem;
    margin-bottom: 1rem;
  }

  .harga-main-image {
    width: 100%;
    height: auto;
    max-width: 480px;
    margin-inline: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  .harga-main-caption {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    opacity: 0.8;
  }
</style>
