---
import { localizePath } from "../utils/url";
import { DEFAULT_LOCALE, t, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const label = t(locale).backLink.label;
---

<a class="back-link" href={localizePath(locale, "/")}>
  <span aria-hidden="true">‹</span> {label}
</a>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 1.5rem;
    font-weight: 700;
    text-decoration: none;
  }
</style>
