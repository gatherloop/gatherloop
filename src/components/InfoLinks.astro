---
import { ADDRESS, GOOGLE_MAPS_URL } from "../consts";
import { localizePath } from "../utils/url";
import { DEFAULT_LOCALE, t, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const dict = t(locale).infoLinks;
---

<section class="info-links" aria-label={dict.ariaLabel}>
  <h2 class="section-title">{dict.sectionTitle}</h2>
  <a class="link-card" href={localizePath(locale, "/games")}>
    <span class="link-icon" aria-hidden="true">🎲</span>
    <span class="link-body">
      <span class="link-title">{dict.games}</span>
    </span>
    <span class="link-chevron" aria-hidden="true">›</span>
  </a>

  <a class="link-card" href={localizePath(locale, "/menu")}>
    <span class="link-icon" aria-hidden="true">☕</span>
    <span class="link-body">
      <span class="link-title">{dict.menu}</span>
    </span>
    <span class="link-chevron" aria-hidden="true">›</span>
  </a>

  <a class="link-card" href={GOOGLE_MAPS_URL} target="_blank" rel="noopener">
    <span class="link-icon" aria-hidden="true">📍</span>
    <span class="link-body">
      <span class="link-title">{dict.location}</span>
      <span class="link-subtitle">{ADDRESS}</span>
    </span>
    <span class="link-chevron" aria-hidden="true">↗</span>
  </a>
</section>

<style>
  .section-title {
    font-size: 1.375rem;
    margin-bottom: 1rem;
    text-align: center;
  }

  .info-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 48px;
    padding: 0.875rem 1rem;
    border-radius: var(--radius-lg);
    background: #fff;
    box-shadow: var(--shadow-card);
    color: var(--color-text);
    text-decoration: none;
  }

  .link-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .link-body {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .link-title {
    font-weight: 700;
  }

  .link-subtitle {
    margin-top: 0.125rem;
    font-size: 0.875rem;
    opacity: 0.8;
  }

  .link-chevron {
    font-size: 1.25rem;
    color: var(--color-accent);
  }
</style>
