---
---

<section class="game-filters" id="game-filters" aria-label="Filter game" hidden>
  <div class="filter-field">
    <label for="filter-title" class="filter-label">Judul</label>
    <input
      type="search"
      id="filter-title"
      name="title"
      class="filter-input"
      placeholder="🔍 Cari judul game…"
      autocomplete="off"
    />
  </div>
  <button type="button" id="filter-reset" class="filter-reset" hidden>
    Reset filter
  </button>
</section>
<p id="filter-count" class="filter-count" aria-live="polite" hidden></p>

<script>
  const panel = document.getElementById("game-filters");
  const titleInput = document.getElementById("filter-title") as HTMLInputElement | null;
  const resetButton = document.getElementById("filter-reset");
  const countEl = document.getElementById("filter-count");
  const emptyEl = document.getElementById("filter-empty");
  const grid = document.getElementById("game-grid");

  if (panel && titleInput && resetButton && countEl && emptyEl && grid) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>(".game-card"));
    const total = cards.length;

    let title = "";
    let debounceTimer: ReturnType<typeof setTimeout> | undefined;

    function render() {
      let visible = 0;
      for (const card of cards) {
        const matches = !title || (card.dataset.title ?? "").includes(title);
        card.hidden = !matches;
        if (matches) visible++;
      }

      countEl!.textContent =
        visible === total ? `${total} game` : `Menampilkan ${visible} dari ${total} game`;
      emptyEl!.hidden = visible !== 0;
      resetButton!.hidden = title === "";
    }

    titleInput.addEventListener("input", () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        title = titleInput.value.trim().toLowerCase();
        render();
      }, 150);
    });

    resetButton.addEventListener("click", () => {
      clearTimeout(debounceTimer);
      titleInput.value = "";
      title = "";
      render();
      titleInput.focus();
    });

    panel.hidden = false;
    countEl.hidden = false;
    render();
  }
</script>

<style>
  .game-filters {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .filter-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    flex: 1 1 200px;
  }

  .filter-label {
    font-size: 0.875rem;
    font-weight: 700;
  }

  .filter-input {
    min-height: 44px;
    padding: 0.625rem 0.875rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: #fff;
    font: inherit;
    color: inherit;
  }

  .filter-input:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }

  .filter-reset {
    min-height: 44px;
    padding: 0 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-accent);
    background: transparent;
    color: var(--color-accent);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .filter-reset:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .filter-count {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    opacity: 0.85;
  }
</style>
