---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import BackLink from "../components/BackLink.astro";
import LanguageSwitch from "../components/LanguageSwitch.astro";
import GameCard from "../components/GameCard.astro";
import GameFilters from "../components/GameFilters.astro";
import games from "../data/games.json";
import type { Game } from "../types";
import { DEFAULT_LOCALE, t } from "../i18n";

const locale = DEFAULT_LOCALE;
const dict = t(locale).gamesPage;
const path = "/games";

const gameList: Game[] = games;
---

<Layout locale={locale} title={dict.title} description={dict.description}>
  <main>
    <div class="page-header-row">
      <BackLink locale={locale} />
      <LanguageSwitch locale={locale} path={path} />
    </div>
    <h1 class="page-title">{dict.heading}</h1>
    <GameFilters locale={locale} />
    <div class="game-grid" id="game-grid">
      {gameList.map((game) => <GameCard game={game} locale={locale} />)}
    </div>
    <p id="filter-empty" class="filter-empty" hidden>
      {dict.emptyState}
    </p>
  </main>
  <Footer locale={locale} path={path} />
</Layout>

<style>
  .page-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .page-title {
    margin-top: 1rem;
    font-size: 1.5rem;
  }

  .game-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 480px) {
    .game-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .filter-empty {
    margin-top: 1.5rem;
    text-align: center;
    opacity: 0.85;
  }
</style>
