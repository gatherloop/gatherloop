---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import Activities from "../../components/Activities.astro";
import HargaMain from "../../components/HargaMain.astro";
import InfoLinks from "../../components/InfoLinks.astro";
import Faq from "../../components/Faq.astro";
import Footer from "../../components/Footer.astro";

const locale = "en";
const path = "/";
---

<Layout locale={locale} path={path}>
  <main>
    <Hero locale={locale} path={path} />
    <Activities locale={locale} />
    <HargaMain locale={locale} />
    <InfoLinks locale={locale} />
    <Faq locale={locale} />
  </main>
  <Footer locale={locale} path={path} />
</Layout>
