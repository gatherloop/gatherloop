---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import BackLink from "../../components/BackLink.astro";
import { withBase } from "../../utils/url";
import { t } from "../../i18n";

const locale = "en";
const dict = t(locale).menuPage;

// Add or remove entries to change how many menu pages are shown — no other code
// change needed. Each `src` file lives in public/images/menu/.
const menuImages = [
  {
    src: "/images/menu.webp",
    alt: dict.imageAlt,
  },
];
---

<Layout locale={locale} title={dict.title} description={dict.description}>
  <main>
    <BackLink locale={locale} />
    <h1 class="page-title">{dict.heading}</h1>
    <div class="menu-images">
      {
        menuImages.map((image) => (
          <img
            class="menu-image"
            src={withBase(image.src)}
            alt={image.alt}
            width="480"
            height="640"
            loading="lazy"
          />
        ))
      }
    </div>
  </main>
  <Footer locale={locale} />
</Layout>

<style>
  .page-title {
    margin-top: 1rem;
    font-size: 1.5rem;
  }

  .menu-images {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .menu-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }
</style>
